# Public-history default: keep the repository closed unless a path is
# explicitly allowed below. This prevents accidental publication of non-public
# coordination notes, docs, build products, or future scratch files.
*

# Public-safe project metadata and build entrypoints.
!/.gitignore
!/LICENSE
!/README.md
!/STATUS.md
!/CONTRIBUTING.md
!/silt.cabal
!/cabal.project

# Public-safe technical implementation surfaces.
!/app/
!/app/**
!/src/
!/src/**
!/test/
!/test/**
!/examples/
!/examples/**
!/scripts/
!/scripts/**
!/support/
!/support/**

# Public Silt Book and its publication workflow.
!/.github/
!/.github/workflows/
!/.github/workflows/book.yml
!/book/
!/book/**
!/site/
!/site/**
/site/.spago/
/site/output/
/site/node_modules/

# Explicit quarantine: not part of the public-safe history.
/docs/

# Generated/local outputs.
dist-newstyle/
out/
cabal.project.local
*.hi
*.o
*.dyn_hi
*.dyn_o
*.prof
*.aux
*.hp
*.eventlog

# Local environment and editor files.
.env
.env.*
.direnv/
.vscode/
.idea/
*.swp
*~
