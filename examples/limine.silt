  ((u8 83) (u8 73) (u8 76) (u8 84) (u8 95)
   (u8 66) (u8 79) (u8 79) (u8 84) (u8 95)
   (u8 80) (u8 79) (u8 76) (u8 73) (u8 67)
   (u8 89) (u8 95) (u8 79) (u8 75) (u8 10)))

(claim limine-boot-policy-ok-slice SerialSlice)
(def limine-boot-policy-ok-slice
  (layout-values SerialSlice limine-boot-policy-ok-bytes limine-boot-policy-ok-bytes-len))

(claim serial-write-boot-policy-ok (Eff SerialReady SerialReady Unit))
(def serial-write-boot-policy-ok
  (serial-write-slice20 limine-boot-policy-ok-slice))

(static-bytes limine-memmap-ok-bytes
  ((u8 83) (u8 73) (u8 76) (u8 84) (u8 95)
   (u8 77) (u8 69) (u8 77) (u8 77) (u8 65) (u8 80)
   (u8 95) (u8 81) (u8 69) (u8 77) (u8 85)
   (u8 95) (u8 79) (u8 75) (u8 10)))

(claim limine-memmap-ok-slice SerialSlice)
(def limine-memmap-ok-slice
  (layout-values SerialSlice limine-memmap-ok-bytes limine-memmap-ok-bytes-len))

