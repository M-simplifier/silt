; Limine success entry fragment.
; Includes the shared serial/debug-exit surface directly.

(include limine-serial.silt)
(include limine-protocol.silt)

(layout BootState 16 8
  ((phase U64 0)
   (code U64 8)))

(layout BootInfo 40 8
  ((hhdm-offset U64 0)
   (memmap-count U64 8)
   (first-base U64 16)
   (first-length U64 24)
   (first-kind U64 32)))

(layout KernelBootSpan 40 8
  ((physical-base U64 0)
   (physical-end U64 8)
   (direct-base U64 16)
   (direct-end U64 24)
   (kind U64 32)))

(layout KernelBootPolicy 24 8
  ((required-pages U64 0)
   (available-pages U64 8)
   (accepted U64 16)))

(static-cell limine-boot-state BootState)
(static-cell limine-boot-info BootInfo)
(static-cell limine-kernel-span KernelBootSpan)
(static-cell limine-kernel-page-count U64)
(static-cell limine-kernel-policy KernelBootPolicy)

(data KernelDone ())

(claim limine-state-ok-message SerialMsg15)
(def limine-state-ok-message
  (layout-values SerialMsg15
    (u64 83)
    (u64 73)
    (u64 76)
    (u64 84)
    (u64 95)
    (u64 83)
    (u64 84)
    (u64 65)
    (u64 84)
    (u64 69)
    (u64 95)
    (u64 79)
    (u64 75)
    (u64 33)
    (u64 10)))

(claim serial-write-state-ok (Eff SerialReady SerialReady Unit))
(def serial-write-state-ok
  (serial-write-msg15 limine-state-ok-message))

(claim limine-image-ok-message SerialMsg15)
(def limine-image-ok-message
  (layout-values SerialMsg15
    (u64 83)
    (u64 73)
    (u64 76)
    (u64 84)
    (u64 95)
    (u64 73)
    (u64 77)
    (u64 65)
    (u64 71)
    (u64 69)
    (u64 95)
    (u64 79)
    (u64 75)
    (u64 33)
    (u64 10)))

(claim serial-write-image-ok (Eff SerialReady SerialReady Unit))
(def serial-write-image-ok
  (serial-write-msg15 limine-image-ok-message))

(claim serial-write-state-and-image-ok (Eff SerialReady SerialReady Unit))
(def serial-write-state-and-image-ok
  (serial-seq serial-write-state-ok serial-write-image-ok))

(claim limine-hhdm-ok-message SerialMsg15)
(def limine-hhdm-ok-message
  (layout-values SerialMsg15
    (u64 83)
    (u64 73)
    (u64 76)
    (u64 84)
    (u64 95)
    (u64 72)
    (u64 72)
    (u64 68)
    (u64 77)
    (u64 95)
    (u64 79)
    (u64 75)
    (u64 33)
    (u64 33)
    (u64 10)))

(claim serial-write-hhdm-ok (Eff SerialReady SerialReady Unit))
(def serial-write-hhdm-ok
  (serial-write-msg15 limine-hhdm-ok-message))

(static-bytes limine-boot-info-ok-bytes
  ((u8 83) (u8 73) (u8 76) (u8 84) (u8 95)
   (u8 66) (u8 79) (u8 79) (u8 84) (u8 95)
   (u8 73) (u8 78) (u8 70) (u8 79) (u8 95)
   (u8 79) (u8 75) (u8 33) (u8 33) (u8 10)))

(claim limine-boot-info-ok-slice SerialSlice)
(def limine-boot-info-ok-slice
  (layout-values SerialSlice limine-boot-info-ok-bytes limine-boot-info-ok-bytes-len))

(claim serial-write-boot-info-ok (Eff SerialReady SerialReady Unit))
(def serial-write-boot-info-ok
  (serial-write-slice20 limine-boot-info-ok-slice))

(static-bytes limine-boot-span-ok-bytes
  ((u8 83) (u8 73) (u8 76) (u8 84) (u8 95)
   (u8 66) (u8 79) (u8 79) (u8 84) (u8 95)
   (u8 83) (u8 80) (u8 65) (u8 78) (u8 95)
   (u8 79) (u8 75) (u8 33) (u8 33) (u8 10)))

(claim limine-boot-span-ok-slice SerialSlice)
(def limine-boot-span-ok-slice
  (layout-values SerialSlice limine-boot-span-ok-bytes limine-boot-span-ok-bytes-len))

(claim serial-write-boot-span-ok (Eff SerialReady SerialReady Unit))
(def serial-write-boot-span-ok
  (serial-write-slice20 limine-boot-span-ok-slice))

(static-bytes limine-kernel-span-ok-bytes
  ((u8 83) (u8 73) (u8 76) (u8 84) (u8 95)
   (u8 75) (u8 69) (u8 82) (u8 78) (u8 69)
   (u8 76) (u8 95) (u8 83) (u8 80) (u8 65)
   (u8 78) (u8 95) (u8 79) (u8 75) (u8 10)))

(claim limine-kernel-span-ok-slice SerialSlice)
(def limine-kernel-span-ok-slice
  (layout-values SerialSlice limine-kernel-span-ok-bytes limine-kernel-span-ok-bytes-len))

(claim serial-write-kernel-span-ok (Eff SerialReady SerialReady Unit))
(def serial-write-kernel-span-ok
  (serial-write-slice20 limine-kernel-span-ok-slice))

(static-bytes limine-kernel-pages-ok-bytes
  ((u8 83) (u8 73) (u8 76) (u8 84) (u8 95)
   (u8 75) (u8 80) (u8 65) (u8 71) (u8 69)
   (u8 83) (u8 95) (u8 79) (u8 75) (u8 33)
   (u8 33) (u8 33) (u8 33) (u8 33) (u8 10)))

(claim limine-kernel-pages-ok-slice SerialSlice)
(def limine-kernel-pages-ok-slice
  (layout-values SerialSlice limine-kernel-pages-ok-bytes limine-kernel-pages-ok-bytes-len))

